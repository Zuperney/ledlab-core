{
  "name": "ledlab-core",
  "private": true,
  "version": "0.20.12",
  "description": "LedLab Core — engenharia de painéis de LED para eventos",
  "author": "LedLab",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "preview": "vite preview",
    "electron:dev": "electron .",
    "dist": "vite build && electron-builder --win",
    "dist:dir": "vite build && electron-builder --win --dir"
  },
  "build": {
    "appId": "com.ledlab.core",
    "productName": "LedLab Core",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "LedLab-Core-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LedLab Core"
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.1",
    "lucide-react": "^1.18.0",
    "react": "^19.2.6",
    "react-datepicker": "^9.1.0",
    "react-dom": "^19.2.6",
    "wouter": "^3.10.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12",
    "vitest": "^4.1.9"
  }
}
